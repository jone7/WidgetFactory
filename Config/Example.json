{
  "WidgetName": "WBP_ExamplePanel",
  "Description": "Example template - demonstrates Widget Factory features",
  "RootWidget": {
    "Type": "CanvasPanel",
    "Name": "Root",
    "Children": [
      {
        "Type": "Image",
        "Name": "Background",
        "Slot": { "Anchors": "Fill" },
        "Properties": {
          "Color": { "R": 0.0, "G": 0.0, "B": 0.0, "A": 0.7 }
        }
      },
      {
        "Type": "CanvasPanel",
        "Name": "MainContainer",
        "Slot": {
          "Anchors": "Center",
          "Size": { "Width": 800, "Height": 600 },
          "Alignment": { "X": 0.5, "Y": 0.5 }
        },
        "Children": [
          {
            "Type": "TextBlock",
            "Name": "TextTitle",
            "IsVariable": true,
            "Slot": {
              "Anchors": "TopLeft",
              "Position": { "X": 20, "Y": 15 }
            },
            "Properties": {
              "Text": "Panel Title",
              "FontSize": 24,
              "Color": { "R": 1.0, "G": 1.0, "B": 1.0, "A": 1.0 }
            }
          },
          {
            "Type": "Button",
            "Name": "BtnClose",
            "IsVariable": true,
            "Slot": {
              "Anchors": "TopRight",
              "Position": { "X": -10, "Y": 10 },
              "Size": { "Width": 40, "Height": 40 },
              "Alignment": { "X": 1.0, "Y": 0.0 }
            },
            "Children": [
              {
                "Type": "TextBlock",
                "Properties": { "Text": "X", "FontSize": 18 }
              }
            ]
          },
          {
            "Type": "ScrollBox",
            "Name": "ItemList",
            "Slot": {
              "Anchors": "TopLeft",
              "Position": { "X": 10, "Y": 60 },
              "Size": { "Width": 300, "Height": 520 }
            },
            "Children": [
              {
                "Type": "CanvasPanel",
                "Name": "ItemListBox",
                "IsVariable": true
              }
            ]
          },
          {
            "Type": "CanvasPanel",
            "Name": "DetailPanel",
            "IsVariable": true,
            "Slot": {
              "Anchors": "TopLeft",
              "Position": { "X": 330, "Y": 60 },
              "Size": { "Width": 450, "Height": 520 }
            },
            "Properties": { "Visibility": "Collapsed" },
            "Children": [
              {
                "Type": "TextBlock",
                "Name": "TextDetailName",
                "IsVariable": true,
                "Slot": {
                  "Anchors": "TopLeft",
                  "Position": { "X": 10, "Y": 10 }
                },
                "Properties": { "Text": "Select an item", "FontSize": 20 }
              },
              {
                "Type": "TextBlock",
                "Name": "TextDetailDesc",
                "IsVariable": true,
                "Slot": {
                  "Anchors": "TopLeft",
                  "Position": { "X": 10, "Y": 50 },
                  "Size": { "Width": 430, "Height": 300 }
                },
                "Properties": { "Text": "", "FontSize": 14, "AutoWrap": true }
              },
              {
                "Type": "Button",
                "Name": "BtnAction",
                "IsVariable": true,
                "Slot": {
                  "Anchors": "BottomLeft",
                  "Position": { "X": 10, "Y": -50 },
                  "Size": { "Width": 120, "Height": 40 }
                },
                "Children": [
                  {
                    "Type": "TextBlock",
                    "Properties": { "Text": "Confirm", "FontSize": 16 }
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "UnLuaBinding": {
    "Enabled": false,
    "ModuleName": "WBP_ExamplePanel_C",
    "_comment": "Set Enabled to true to auto-bind UnLua (requires UnLua plugin)"
  }
}
