{
  "WidgetName": "WBP_ExamplePanel",
  "Description": "示例模板 - 展示 Widget Factory 功能",
  "RootWidget": {
    "Type": "CanvasPanel",
    "Name": "Root",
    "Children": [
      {
        "Type": "Image",
        "Name": "Background",
        "Slot": { "Anchors": "Fill" },
        "Properties": {
          "Color": { "R": 0.0, "G": 0.0, "B": 0.0, "A": 0.7 }
        }
      },
      {
        "Type": "VerticalBox",
        "Name": "MainContainer",
        "Slot": {
          "Anchors": "Center",
          "Size": { "Width": 800, "Height": 600 }
        },
        "Children": [
          {
            "Type": "HorizontalBox",
            "Name": "TitleBar",
            "Slot": { "SizeRule": "Auto", "Padding": { "Left": 10, "Top": 10, "Right": 10, "Bottom": 5 } },
            "Children": [
              {
                "Type": "TextBlock",
                "Name": "TextTitle",
                "IsVariable": true,
                "Slot": { "SizeRule": "Auto", "VAlign": "Center" },
                "Properties": {
                  "Text": "标题",
                  "FontSize": 24,
                  "Color": { "R": 1.0, "G": 1.0, "B": 1.0, "A": 1.0 }
                }
              },
              {
                "Type": "Spacer",
                "Slot": { "SizeRule": "Fill", "FillWidth": 1.0 }
              },
              {
                "Type": "Button",
                "Name": "BtnClose",
                "IsVariable": true,
                "Slot": { "SizeRule": "Auto", "VAlign": "Center" },
                "Children": [
                  {
                    "Type": "TextBlock",
                    "Properties": { "Text": "X", "FontSize": 18 }
                  }
                ]
              }
            ]
          },
          {
            "Type": "HorizontalBox",
            "Name": "ContentArea",
            "Slot": { "SizeRule": "Fill", "FillHeight": 1.0, "Padding": { "Left": 10, "Top": 5, "Right": 10, "Bottom": 10 } },
            "Children": [
              {
                "Type": "ScrollBox",
                "Slot": { "SizeRule": "Fill", "FillWidth": 0.4 },
                "Children": [
                  {
                    "Type": "VerticalBox",
                    "Name": "ItemListBox",
                    "IsVariable": true
                  }
                ]
              },
              {
                "Type": "VerticalBox",
                "Name": "DetailPanel",
                "IsVariable": true,
                "Slot": { "SizeRule": "Fill", "FillWidth": 0.6, "Padding": { "Left": 20, "Top": 0, "Right": 0, "Bottom": 0 } },
                "Properties": { "Visibility": "Collapsed" },
                "Children": [
                  {
                    "Type": "TextBlock",
                    "Name": "TextDetailName",
                    "IsVariable": true,
                    "Properties": { "Text": "选择一个项目", "FontSize": 20 }
                  },
                  {
                    "Type": "TextBlock",
                    "Name": "TextDetailDesc",
                    "IsVariable": true,
                    "Properties": { "Text": "", "FontSize": 14, "AutoWrap": true }
                  },
                  {
                    "Type": "Spacer",
                    "Slot": { "SizeRule": "Fill", "FillHeight": 1.0 }
                  },
                  {
                    "Type": "Button",
                    "Name": "BtnAction",
                    "IsVariable": true,
                    "Slot": { "SizeRule": "Auto", "HAlign": "Left" },
                    "Children": [
                      {
                        "Type": "TextBlock",
                        "Properties": { "Text": "确认", "FontSize": 16 }
                      }
                    ]
                  },
                  {
                    "Type": "TextBlock",
                    "Name": "TextMessage",
                    "IsVariable": true,
                    "Properties": { "Text": "", "FontSize": 14 }
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "UnLuaBinding": {
    "Enabled": false,
    "ModuleName": "WBP_ExamplePanel_C",
    "_comment": "设置 Enabled 为 true 可自动绑定 UnLua（需安装 UnLua 插件）"
  }
}
